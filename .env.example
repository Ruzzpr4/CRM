# ─── MODO MOCK (dados fictícios, sem Supabase) ────────────────────────────────
# true  = roda 100% local, sem internet, sem cadastro em nada
# false = usa o Supabase real (preencher as variáveis abaixo)
VITE_USE_MOCK=true

# ─── Supabase (só necessário quando VITE_USE_MOCK=false) ──────────────────────
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# ─── Webhook (só necessário quando VITE_USE_MOCK=false) ───────────────────────
VITE_WEBHOOK_SECRET=seu-segredo-webhook-aqui
